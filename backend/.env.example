DATABASE_URL=postgres://postgres:postgres@localhost:5432/bus_tracker?sslmode=disable
CTA_API_KEY=your_cta_api_key_here

# Headway pipeline (optional)
PIPELINE_ENABLED=false
# Leave unset in production to monitor all routes from the latest ridership import.
# Set explicitly for local testing, e.g. PIPELINE_ROUTES=8,66
# PIPELINE_ROUTES=8,66
PIPELINE_POLL_INTERVAL=30s
PIPELINE_USE_FAKE_CTA=false

# Admin UI (PR 2)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
# Optional — defaults to a hash of username:password if unset
# ADMIN_SESSION_SECRET=
